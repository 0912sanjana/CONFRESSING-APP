# Server
HOST=0.0.0.0
PORT=8000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5433/kiit_conference

# Kafka
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC_MEETING_EVENTS=meeting.events

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_WS_URL=wss://your-livekit-domain
# LiveKit WS URL is used by frontend, not required for token gen, but keep in config.